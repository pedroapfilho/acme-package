{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "oxlint.config.ts",
    "**/tsdown.config.ts",
    "apps/demo-vite/src/main.tsx",
    "apps/docs/app/layout.tsx",
    "apps/docs/source.config.ts"
